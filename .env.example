# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=greenlabs
DB_PASSWORD=greenlabs_password
DB_DATABASE=greenlabs_blog

# CDN Configuration (ArvanCloud)
ARVAN_API_KEY=your_arvan_api_key_here
ARVAN_CDN_DOMAIN=your-domain.cdn.arvancdn.ir

# Or use Cloudinary
# CDN_CLOUD_NAME=your_cloudinary_cloud_name
# CDN_API_KEY=your_cloudinary_api_key
# CDN_API_SECRET=your_cloudinary_api_secret

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-at-least-32-chars
JWT_EXPIRES_IN=24h

# Application
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://localhost:4200

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
